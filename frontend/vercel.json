{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://replace-with-render-backend-url/api/$1"
    },
    {
      "source": "/health",
      "destination": "https://replace-with-render-backend-url/health"
    }
  ]
}
